install.packages("RMySQL")
#| label: load-packages
#| include: false
library(tidyverse)
library(kableExtra)
library(mdsr)
library(RMySQL)
# SQL commands
con <- dbConnect_scidb("airlines")
query1 <- "SHOW TABLES"
dbGetQuery(con, query1)
query2 <- "DESCRIBE flights"
dbGetQuery(con, query2)
query3 <- "SELECT COUNT(*) as N
FROM flights
WHERE dest = 'ORD' AND year = 2014 AND origin = 'BDL'
"
dbGetQuery(con, query3)
query4 <- "SELECT COUNT(*) as N
FROM flights
WHERE dest = 'BDL' AND year = 2014 AND origin = 'ORD'
"
dbGetQuery(con, query4)
query5 <- "SELECT COUNT(*) as N
FROM flights
WHERE dest = 'PDX' AND year = 2014 AND month = 'may' AND day = 14
"
dbGetQuery(con, query5)
query5 <- "SELECT COUNT(*) as N
FROM flights
WHERE dest = 'PDX' AND year = 2014 AND month = 'May' AND day = 14
"
dbGetQuery(con, query5)
query5 <- "SELECT COUNT(*) as N
FROM flights
WHERE dest = 'PDX' AND year = 2014 AND month = 5 AND day = 14
"
dbGetQuery(con, query5)
query6 <- "SELECT arr_delay,
SUM(1) as Total
FROM flights
WHERE dest = 'LAX' AND year = 2014
GROUP BY carrier
"
dbGetQuery(con, query6)
#| label: load-packages
#| include: false
library(tidyverse)
library(kableExtra)
library(mdsr)
library(RMySQL)
# SQL commands
con <- dbConnect_scidb("airlines")
query1 <- "SHOW TABLES"
dbGetQuery(con, query1)
query2 <- "DESCRIBE flights"
dbGetQuery(con, query2)
query3 <- "SELECT COUNT(*) as N
FROM flights
WHERE dest = 'ORD' AND year = 2014 AND origin = 'BDL'
"
dbGetQuery(con, query3)
query4 <- "SELECT COUNT(*) as N
FROM flights
WHERE dest = 'BDL' AND year = 2014 AND origin = 'ORD'
"
dbGetQuery(con, query4)
query5 <- "SELECT COUNT(*) as N
FROM flights
WHERE dest = 'PDX' AND year = 2014 AND month = 5 AND day = 14
"
dbGetQuery(con, query5)
query6 <- "SELECT arr_delay,
SUM(1) as Total
FROM flights
WHERE dest = 'LAX' AND year = 2014
GROUP BY carrier
"
dbGetQuery(con, query6)
query6 <- "SELECT carrier, arr_delay,
SUM(1) as Total
FROM flights
WHERE dest = 'LAX' AND year = 2014
GROUP BY carrier
"
dbGetQuery(con, query6)
query6 <- "SELECT carrier, arr_delay,
SUM(*) as Total
FROM flights
WHERE dest = 'LAX' AND year = 2014
GROUP BY carrier
"
dbGetQuery(con, query6)
query6 <- "SELECT carrier, arr_delay,
SUM(1) as Total
FROM flights
WHERE dest = 'LAX' AND year = 2014
GROUP BY carrier
"
dbGetQuery(con, query6)
query6 <- "SELECT carrier,
SUM(1) as Total
FROM flights
WHERE dest = 'LAX' AND year = 2014
GROUP BY carrier
"
dbGetQuery(con, query6)
query6 <- "SELECT carrier, arr_delay,
SUM(1) as Total
FROM flights
WHERE dest = 'LAX' AND year = 2014
GROUP BY carrier
"
dbGetQuery(con, query6)
query6 <- "SELECT carrier, arr_delay,
SUM(arr_delay) as TotalDelay
FROM flights
WHERE dest = 'LAX' AND year = 2014
GROUP BY carrier
"
dbGetQuery(con, query6)
query6 <- "SELECT carrier,
SUM(arr_delay) as TotalDelay
FROM flights
WHERE dest = 'LAX' AND year = 2014
GROUP BY carrier
"
dbGetQuery(con, query6)
query6 <- "SELECT carrier,
SUM(arr_delay) as TotalDelay
COUNT(*) as TotalFlights
FROM flights
WHERE dest = 'LAX' AND year = 2014
GROUP BY carrier
"
dbGetQuery(con, query6)
query6 <- "SELECT carrier,
SUM(arr_delay) as TotalDelay
COUNT(carrier) as TotalFlights
FROM flights
WHERE dest = 'LAX' AND year = 2014
GROUP BY carrier
"
dbGetQuery(con, query6)
query6 <- "SELECT carrier,
SUM(arr_delay) as TotalDelay,
COUNT(*) as TotalFlights
FROM flights
WHERE dest = 'LAX' AND year = 2014
GROUP BY carrier
"
dbGetQuery(con, query6)
